{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "GeleitMail",
  "identifier": "app.geleitmail",
  "build": {
    "frontendDist": "dist"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [],
    "security": {
      "csp": "default-src 'self'; script-src 'self' 'wasm-unsafe-eval'; style-src 'self'; img-src 'self' data:; font-src 'self' data:; connect-src 'self' ipc: http://ipc.localhost; frame-src mail: http://mail.localhost; object-src 'none'; base-uri 'none'; form-action 'none'",
      "assetProtocol": {
        "enable": false
      }
    }
  },
  "bundle": {
    "active": false,
    "icon": [
      "icons/icon.png"
    ],
    "createUpdaterArtifacts": true
  },
  "plugins": {
    "updater": {
      "endpoints": [
        "https://github.com/aschollwoeck/geleit/releases/latest/download/latest.json"
      ],
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IEY3RDIxQjY0RDU1NEI0M0EKUldRNnRGVFZaQnZTOXpXa2RkQ2lXQWx2RlRxZVpNRXdldE9WczcvOGdGcW42UjJuejJKb3pvSTgK"
    }
  }
}